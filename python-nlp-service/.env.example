# Environment variables for local development
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_service_key

# ============================================
# AI PROVIDER
# ============================================
# Server-side only. Do not expose this key in browser builds.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5
OPENAI_SIMPLE_MODEL=gpt-5.4-mini
OPENAI_CRITICAL_MODEL=gpt-5.5
OPENAI_CLINICAL_REASONING=high
OPENAI_CRITICAL_REASONING=xhigh
OPENAI_SIMPLE_REASONING=low
OPENAI_TIMEOUT_SECONDS=90

# NCBI API Key (for PubMed searches - optional but recommended)
NCBI_API_KEY=your_ncbi_api_key
