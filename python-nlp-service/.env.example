# Environment variables for local development
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_service_key

# ============================================
# AI PROVIDERS (fallback: Anthropic -> Gemini)
# ============================================
# Primary: Anthropic Claude (optional if Gemini is configured)
CLAUDE_API_KEY=your_anthropic_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key  # Alternative name

# Fallback: Google Gemini (used if Anthropic fails or is not configured)
GEMINI_API_KEY=your_gemini_api_key

# NCBI API Key (for PubMed searches - optional but recommended)
NCBI_API_KEY=your_ncbi_api_key
